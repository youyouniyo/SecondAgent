# Confluence 접속 정보입니다.
# Confluence Cloud를 사용한다면 PASSWORD 자리에는 Atlassian API Token을 넣어도 됩니다.
CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_ID=your-email@example.com
CONFLUENCE_PASSWORD=your-password-or-api-token

# LLM API 호출 정보입니다.
OPENAI_API_KEY=your-openai-api-key
LLM_EVALUATION_MODELS=gpt-4.1,gpt-4.1-mini,o4-mini
LLM_AGGREGATOR_MODEL=gpt-4.1
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0

# 로컬 개발 편의를 위한 설정입니다.
APP_DATABASE_PATH=./data/app.db
ALLOW_DEMO_FALLBACK=true
